@startuml
|User|
start
:Login to system;
:Search/Browse equipment;
:Select equipment and time slot;

|System|
:Check equipment availability;

if (Equipment available?) then (Yes)
  ' continue
else (No)
  :Display: "Not available";
  |User|
  :Choose different time/equipment;
  |System|
  :Check equipment availability;
endif

|System|
:Calculate fee based on user type\n(Student: $10, Faculty: $15,\nResearcher: $20, Guest: $30);

|User|
:Confirm booking details;

|System|
:Calculate deposit (1 hour fee);
:Initiate payment process;

|Payment System|
:Process payment;

if (Payment successful?) then (Yes)
  ' continue
else (No)
  :Display: "Payment failed";
  |User|
  :Try different payment method;
  |System|
  :Initiate payment process;
  |Payment System|
  :Process payment;
endif

|System|
:Create reservation with status "Pending Check-in";
:Send confirmation email;
:Display: "Reservation confirmed";

stop
@enduml
